{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "Node16",
    "moduleResolution": "node16",
    "outDir": "out",
    "lib": ["ES2023", "DOM"],
    "types": ["node", "jest"],
    "paths": {
      "@anytime-markdown/trail-db": ["../trail-db/src/index.ts"],
