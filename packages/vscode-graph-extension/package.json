{
  "name": "anytime-graph",
  "displayName": "Anytime Graph",
  "description": "Graph whiteboard editor for VS Code",
  "version": "0.1.5",
  "license": "MIT",
  "publisher": "anytime-trial",
  "repository": {
    "type": "git",
    "url": "https://github.com/anytime-trial/anytime-markdown.git"
  },
  "engines": {
    "vscode": "^1.109.0"
  },
  "icon": "images/camel_graph.png",
  "categories": [
    "Visualization"
  ],
  "keywords": [
    "graph",
    "whiteboard",
    "diagram",
    "canvas"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "anytimeGraph",
          "title": "Anytime Graph",
          "icon": "images/graph-activitybar.svg"
        }
      ]
    },
    "customEditors": [
      {
        "viewType": "anytimeGraph",
        "displayName": "Graph Editor",
        "selector": [
          {
            "filenamePattern": "*.graph"
          }
        ],
        "priority": "default"
      }
    ],
    "commands": [
      {
        "command": "anytime-graph.newGraph",
        "title": "Anytime Graph: New Graph"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map"
  },
  "devDependencies": {
    "@types/node": "22.x",
    "@types/vscode": "1.109.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "ts-loader": "9.5.4",
    "typescript": "5.9.3",
    "webpack": "5.104.1",
    "webpack-cli": "6.0.1"
  },
  "dependencies": {
    "@anytime-markdown/graph-core": "*",
    "@anytime-markdown/trail-core": "*",
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.0",
    "@mui/icons-material": "7.3.7",
    "@mui/material": "7.3.7",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  }
}
