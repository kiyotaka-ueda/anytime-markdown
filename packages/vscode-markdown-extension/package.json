{
  "name": "anytime-markdown",
  "displayName": "%displayName%",
  "description": "%description%",
  "version": "0.9.3",
  "license": "MIT",
  "publisher": "anytime-trial",
  "repository": {
    "type": "git",
    "url": "https://github.com/anytime-trial/anytime-markdown.git"
  },
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "sdd",
    "image prompt",
    "markdown",
    "mermaid",
    "plantuml"
  ],
  "activationEvents": [
    "onLanguage:markdown"
  ],
  "icon": "images/camel_markdown.png",
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "anytimeMarkdown",
          "title": "%viewsContainer.title%",
          "icon": "images/camel-activitybar.svg"
        }
      ]
    },
    "views": {
      "anytimeMarkdown": [
        {
          "id": "anytimeMarkdown.aiNote",
          "name": "Agent Note",
          "initialSize": 1
        },
        {
          "id": "anytimeMarkdown.aiLog",
          "name": "Agent Log",
          "initialSize": 2
        },
        {
          "id": "anytimeMarkdown.aiMemory",
          "name": "Agent Memory",
          "initialSize": 2
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "anytimeMarkdown.aiNote",
        "contents": "%viewsWelcome.aiNote%"
      }
    ],
    "submenus": [
      {
        "id": "anytime-markdown.modeMenu.review",
        "label": "%submenu.editorMode%",
        "icon": "$(eye)"
      },
      {
        "id": "anytime-markdown.modeMenu.wysiwyg",
        "label": "%submenu.editorMode%",
        "icon": "$(edit)"
      },
      {
        "id": "anytime-markdown.modeMenu.source",
        "label": "%submenu.editorMode%",
        "icon": "$(code)"
      }
    ],
    "commands": [
      {
        "command": "anytime-markdown.openEditorWithFile",
        "title": "%command.openEditorWithFile%"
      },
      {
        "command": "anytime-markdown.compareWithMarkdownEditor",
        "title": "%command.compareWithMarkdownEditor%",
        "enablement": "activeCustomEditorId == anytimeMarkdown"
      },
      {
        "command": "anytime-markdown.insertSectionNumbers",
        "title": "%command.insertSectionNumbers%",
        "icon": "$(list-ordered)"
      },
      {
        "command": "anytime-markdown.removeSectionNumbers",
        "title": "%command.removeSectionNumbers%",
        "icon": "$(list-flat)"
      },
      {
        "command": "anytime-markdown.pasteAsMarkdown",
        "title": "%command.pasteAsMarkdown%"
      },
      {
        "command": "anytime-markdown.openContext",
        "title": "%command.openContext%",
        "icon": "$(note)"
      },
      {
        "command": "anytime-markdown.copyContextPath",
        "title": "%command.copyContextPath%",
        "icon": "$(clippy)"
      },
      {
        "command": "anytime-markdown.clearContext",
        "title": "%command.clearContext%",
        "icon": "$(trash)"
      },
      {
        "command": "anytime-markdown.aiLogRefresh",
        "title": "%command.aiLogRefresh%",
        "icon": "$(refresh)"
      },
      {
        "command": "anytime-markdown.aiMemoryRefresh",
        "title": "%command.aiMemoryRefresh%",
        "icon": "$(refresh)"
      },
      {
        "command": "anytime-markdown.toggleAutoReloadOff",
        "title": "%command.autoReloadDisable%",
        "icon": "$(sync)",
        "enablement": "activeCustomEditorId == anytimeMarkdown"
      },
      {
        "command": "anytime-markdown.toggleAutoReloadOn",
        "title": "%command.autoReloadEnable%",
        "icon": "$(sync-ignored)",
        "enablement": "activeCustomEditorId == anytimeMarkdown"
      },
      {
        "command": "anytime-markdown.switchToReview",
        "title": "%command.switchToReview%",
        "icon": "$(eye)",
        "enablement": "activeCustomEditorId == anytimeMarkdown"
      },
      {
        "command": "anytime-markdown.switchToWysiwyg",
        "title": "%command.switchToWysiwyg%",
        "icon": "$(edit)",
        "enablement": "activeCustomEditorId == anytimeMarkdown"
      },
      {
        "command": "anytime-markdown.switchToSource",
        "title": "%command.switchToSource%",
        "icon": "$(code)",
        "enablement": "activeCustomEditorId == anytimeMarkdown"
      }
    ],
    "customEditors": [
      {
        "viewType": "anytimeMarkdown",
        "displayName": "%customEditor.displayName%",
        "selector": [
          {
            "filenamePattern": "*.md"
          },
          {
            "filenamePattern": "*.markdown"
          }
        ],
        "priority": "option"
      }
    ],
    "configuration": {
      "title": "%configuration.title%",
      "properties": {
        "anytimeMarkdown.fontSize": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "maximum": 72,
          "description": "%configuration.fontSize.description%"
        },
        "anytimeMarkdown.editorMaxWidth": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "maximum": 10000,
          "description": "%configuration.editorMaxWidth.description%"
        },
        "anytimeMarkdown.language": {
          "type": "string",
          "default": "auto",
          "enum": [
            "auto",
            "en",
            "ja"
          ],
          "enumDescriptions": [
            "%configuration.language.auto%",
            "English",
            "Japanese"
          ],
          "description": "%configuration.language.description%"
        },
        "anytimeMarkdown.themeMode": {
          "type": "string",
          "default": "auto",
          "enum": [
            "auto",
            "light",
            "dark"
          ],
          "enumDescriptions": [
            "%configuration.themeMode.auto%",
            "%configuration.themeMode.light%",
            "%configuration.themeMode.dark%"
          ],
          "description": "%configuration.themeMode.description%"
        },
        "anytimeMarkdown.themePreset": {
          "type": "string",
          "default": "handwritten",
          "enum": [
            "handwritten",
            "professional"
          ],
          "enumDescriptions": [
            "%configuration.themePreset.handwritten%",
            "%configuration.themePreset.professional%"
          ],
          "description": "%configuration.themePreset.description%"
        }
      }
    },
    "menus": {
      "view/title": [
        {
          "command": "anytime-markdown.clearContext",
          "when": "view == anytimeMarkdown.aiNote",
          "group": "navigation@2"
        },
        {
          "command": "anytime-markdown.aiLogRefresh",
          "when": "view == anytimeMarkdown.aiLog",
          "group": "navigation@1"
        },
        {
          "command": "anytime-markdown.aiMemoryRefresh",
          "when": "view == anytimeMarkdown.aiMemory",
          "group": "navigation@1"
        },
        {
          "command": "anytime-markdown.copyContextPath",
          "when": "view == anytimeMarkdown.aiNote",
          "group": "navigation@1"
        }
      ],
      "explorer/context": [
        {
          "command": "anytime-markdown.openEditorWithFile",
          "when": "resourceLangId == markdown",
          "group": "navigation"
        },
        {
          "command": "anytime-markdown.compareWithMarkdownEditor",
          "when": "resourceLangId == markdown",
          "group": "navigation@2"
        }
      ],
      "editor/title": [
        {
          "command": "anytime-markdown.toggleAutoReloadOff",
          "when": "activeCustomEditorId == anytimeMarkdown && anytimeMarkdown.autoReload != false",
          "group": "navigation@1"
        },
        {
          "command": "anytime-markdown.toggleAutoReloadOn",
          "when": "activeCustomEditorId == anytimeMarkdown && anytimeMarkdown.autoReload == false",
          "group": "navigation@1"
        },
        {
          "submenu": "anytime-markdown.modeMenu.review",
          "when": "activeCustomEditorId == anytimeMarkdown && anytimeMarkdown.editorMode == review",
          "group": "navigation@2"
        },
        {
          "submenu": "anytime-markdown.modeMenu.wysiwyg",
          "when": "activeCustomEditorId == anytimeMarkdown && anytimeMarkdown.editorMode != review && anytimeMarkdown.editorMode != source",
          "group": "navigation@2"
        },
        {
          "submenu": "anytime-markdown.modeMenu.source",
          "when": "activeCustomEditorId == anytimeMarkdown && anytimeMarkdown.editorMode == source",
          "group": "navigation@2"
        }
      ],
      "anytime-markdown.modeMenu.review": [
        {
          "command": "anytime-markdown.switchToReview",
          "group": "1_mode@1"
        },
        {
          "command": "anytime-markdown.switchToWysiwyg",
          "group": "1_mode@2"
        },
        {
          "command": "anytime-markdown.switchToSource",
          "group": "1_mode@3"
        }
      ],
      "anytime-markdown.modeMenu.wysiwyg": [
        {
          "command": "anytime-markdown.switchToReview",
          "group": "1_mode@1"
        },
        {
          "command": "anytime-markdown.switchToWysiwyg",
          "group": "1_mode@2"
        },
        {
          "command": "anytime-markdown.switchToSource",
          "group": "1_mode@3"
        }
      ],
      "anytime-markdown.modeMenu.source": [
        {
          "command": "anytime-markdown.switchToReview",
          "group": "1_mode@1"
        },
        {
          "command": "anytime-markdown.switchToWysiwyg",
          "group": "1_mode@2"
        },
        {
          "command": "anytime-markdown.switchToSource",
          "group": "1_mode@3"
        }
      ],
      "editor/title/context": [
        {
          "command": "anytime-markdown.openEditorWithFile",
          "when": "resourceLangId == markdown",
          "group": "navigation"
        },
        {
          "command": "anytime-markdown.compareWithMarkdownEditor",
          "when": "resourceLangId == markdown",
          "group": "navigation@2"
        }
      ]
    },
    "keybindings": [
      {
        "command": "anytime-markdown.pasteAsMarkdown",
        "key": "ctrl+shift+v",
        "mac": "cmd+shift+v",
        "when": "activeCustomEditorId == anytimeMarkdown"
      }
    ]
  },
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": "limited",
      "description": "Git operations and file system access require workspace trust. Editor and preview features work in untrusted workspaces.",
      "restrictedConfigurations": []
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test || echo \"vscode-test skipped (headless environment)\""
  },
  "devDependencies": {
    "@types/diff": "7.0.2",
    "@types/dompurify": "3.0.5",
    "@types/mocha": "10.0.10",
    "@types/node": "22.x",
    "@types/plantuml-encoder": "1.4.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/vscode": "1.109.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "2.5.2",
    "css-loader": "7.1.4",
    "eslint": "9.39.2",
    "style-loader": "4.0.0",
    "ts-loader": "9.5.4",
    "typescript": "5.9.3",
    "typescript-eslint": "8.54.0",
    "webpack": "5.104.1",
    "webpack-cli": "6.0.1"
  },
  "dependencies": {
    "@anytime-markdown/markdown-core": "*",
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.0",
    "@mui/icons-material": "7.3.7",
    "@mui/material": "7.3.7",
    "diff": "8.0.3",
    "dompurify": "3.3.3",
    "jsxgraph": "1.12.2",
    "marked": "17.0.3",
    "mathjs": "13.2.3",
    "mermaid": "11.12.3",
    "plantuml-encoder": "1.4.0",
    "plotly.js-gl3d-dist-min": "3.4.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  }
}
