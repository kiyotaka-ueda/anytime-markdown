{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "isolatedModules": true,
    "outDir": "out/webview",
    "paths": {
      "@anytime-markdown/graph-core": ["../graph-core/src/index.ts"],
      "@anytime-markdown/graph-core/*": ["../graph-core/*"],
      "@anytime-markdown/c4kernel": ["../c4kernel/src/index.ts"],
      "@anytime-markdown/c4kernel/*": ["../c4kernel/*"]
    }
  },
  "include": [
    "src/c4/webview/**/*",
    "../graph-core/src/**/*",
    "../c4kernel/src/**/*"
  ],
  "exclude": [
    "../graph-core/src/__tests__/**/*",
    "../c4kernel/src/__tests__/**/*"
  ]
}
