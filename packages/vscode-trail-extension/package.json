{
  "name": "anytime-trail",
  "displayName": "%displayName%",
  "description": "%description%",
  "version": "0.15.0",
  "license": "MIT",
  "publisher": "anytime-trial",
  "repository": {
    "type": "git",
    "url": "https://github.com/anytime-trial/anytime-markdown.git"
  },
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Visualization"
  ],
  "keywords": [
    "architecture",
    "trail",
    "dashboard",
    "analysis"
  ],
  "activationEvents": [
    "onView:anytimeTrail.database"
  ],
  "icon": "images/anytime-control-256.png",
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "anytimeTrail",
          "title": "%viewsContainer.title%",
          "icon": "images/trail_activitybar_icon.svg"
        }
      ]
    },
    "views": {
      "anytimeTrail": [
        {
          "id": "anytimeTrail.aiNote",
          "name": "%view.aiNote%"
        },
        {
          "id": "anytimeTrail.dashboard",
          "name": "%view.dashboard%"
        },
        {
          "id": "anytimeTrail.database",
          "name": "%view.database%"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "anytimeTrail.aiNote",
        "contents": "%viewsWelcome.aiNote%"
      },
      {
        "view": "anytimeTrail.dashboard",
        "contents": "%viewsWelcome.dashboard%"
      }
    ],
    "commands": [
      {
        "command": "anytime-trail.openContext",
        "title": "%command.openContext%",
        "icon": "$(note)"
      },
      {
        "command": "anytime-trail.openNoteSkill",
        "title": "%command.openNoteSkill%",
        "icon": "$(book)"
      },
      {
        "command": "anytime-trail.addNotePage",
        "title": "%command.addNotePage%",
        "icon": "$(add)"
      },
      {
        "command": "anytime-trail.deleteNotePage",
        "title": "%command.deleteNotePage%",
        "icon": "$(trash)"
      },
      {
        "command": "anytime-trail.openNotePage",
        "title": "%command.openNotePage%"
      },
      {
        "command": "anytime-trail.clearContext",
        "title": "%command.clearContext%",
        "icon": "$(trash)"
      },
      {
        "command": "anytime-trail.copyContextPath",
        "title": "%command.copyContextPath%",
        "icon": "$(clippy)"
      },
      {
        "command": "anytime-trail.loadCoverage",
        "title": "Load Coverage",
        "icon": "$(beaker)"
      },
      {
        "command": "anytime-trail.openTrailViewer",
        "title": "%command.openTrailViewer%",
        "category": "Anytime Trail",
        "icon": "$(graph-line)"
      },
      {
        "command": "anytime-trail.restoreBackup",
        "title": "%command.restoreBackup%",
        "category": "Anytime Trail",
        "icon": "$(discard)"
      },
      {
        "command": "anytime-trail.importTrailData",
        "title": "Refresh Trail Data",
        "category": "Anytime Trail",
        "icon": "$(refresh)"
      },
      {
        "command": "anytime-trail.c4Analyze",
        "title": "%command.c4Analyze%",
        "category": "Anytime Trail",
        "icon": "$(symbol-class)"
      },
      {
        "command": "anytime-trail.generateCodeGraph",
        "title": "Generate Code Graph",
        "category": "Anytime Trail",
        "icon": "$(graph)"
      },
      {
        "command": "anytime-trail.regenerateCurrentCodeGraph",
        "title": "Regenerate Current Code Graph",
        "category": "Anytime Trail"
      },
      {
        "command": "anytime-trail.regenerateReleaseCodeGraphs",
        "title": "Regenerate Release Code Graphs",
        "category": "Anytime Trail"
      },
      {
        "command": "anytime-trail.runWithTrace",
        "title": "%command.runWithTrace%",
        "category": "Anytime Trail",
        "icon": "$(beaker)"
      }
    ],
    "codeLensProviders": [
      {
        "language": "typescript",
        "scheme": "file"
      },
      {
        "language": "javascript",
        "scheme": "file"
      },
      {
        "language": "json",
        "scheme": "file"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "anytime-trail.openNoteSkill",
          "when": "view == anytimeTrail.aiNote",
          "group": "navigation@1"
        },
        {
          "command": "anytime-trail.addNotePage",
          "when": "view == anytimeTrail.aiNote",
          "group": "navigation@2"
        },
        {
          "command": "anytime-trail.clearContext",
          "when": "view == anytimeTrail.aiNote",
          "group": "navigation@3"
        },
        {
          "command": "anytime-trail.copyContextPath",
          "when": "view == anytimeTrail.aiNote",
          "group": "navigation@3"
        },
        {
          "command": "anytime-trail.importTrailData",
          "when": "view == anytimeTrail.database",
          "group": "navigation@1"
        },
        {
          "command": "anytime-trail.c4Analyze",
          "when": "view == anytimeTrail.database",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "anytime-trail.deleteNotePage",
          "when": "view == anytimeTrail.aiNote && viewItem == noteItem",
          "group": "inline"
        }
      ]
    },
    "configuration": {
      "title": "Anytime Trail",
      "properties": {
        "anytimeTrail.docsPath": {
          "type": "string",
          "default": "",
          "markdownDescription": "Absolute path to the documentation directory for C4 document links. When set, Markdown files with `c4Scope` frontmatter are indexed and shown in the C4 viewer."
        },
        "anytimeTrail.codeGraph.workspacePath": {
          "type": "string",
          "default": "",
          "markdownDescription": "解析対象ワークスペースの絶対パス。空欄の場合は現在開いているワークスペースを使用する。表示名は常に `Workspace` が割り当てられる。"
        },
        "anytimeTrail.trailServer.port": {
          "type": "number",
          "default": 19841,
          "description": "Port number for the Trail Viewer server"
        },
        "anytimeTrail.database.storagePath": {
          "type": "string",
          "default": "",
          "markdownDescription": "%config.database.storagePath%"
        },
        "anytimeTrail.database.backupGenerations": {
          "type": "number",
          "default": 1,
          "minimum": 1,
          "maximum": 10,
          "markdownDescription": "%config.database.backupGenerations%"
        },
        "anytimeTrail.claudeStatus.directory": {
          "type": "string",
          "default": "",
          "markdownDescription": "%config.claudeStatus.directory%"
        },
        "anytimeTrail.budget.dailyLimitTokens": {
          "type": [
            "number",
            "null"
          ],
          "default": null,
          "markdownDescription": "日次トークン上限。`null` で無効。"
        },
        "anytimeTrail.budget.sessionLimitTokens": {
          "type": [
            "number",
            "null"
          ],
          "default": null,
          "markdownDescription": "セッションあたりのトークン上限。`null` で無効。"
        },
        "anytimeTrail.budget.alertThresholdPct": {
          "type": "number",
          "default": 80,
          "minimum": 1,
          "maximum": 100,
          "markdownDescription": "上限に対する警告閾値（%）。"
        }
      }
    }
  },
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": "limited",
      "description": "Git operations and file system access require workspace trust.",
      "restrictedConfigurations": []
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "test": "jest --maxWorkers=1"
  },
  "dependencies": {
    "@anytime-markdown/graph-core": "*",
    "@anytime-markdown/trail-core": "*",
    "@anytime-markdown/trail-db": "*",
    "@anytime-markdown/vscode-common": "*",
    "graphology": "0.26.0",
    "graphology-communities-louvain": "2.0.2",
    "graphology-layout": "0.6.1",
    "graphology-layout-forceatlas2": "0.10.1",
    "graphology-shortest-path": "2.1.0",
    "pg": "8.20.0",
    "sql.js": "1.12.0",
    "typescript": "5.9.3",
    "ws": "8.18.2"
  },
  "devDependencies": {
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.0",
    "@mui/icons-material": "7.3.8",
    "@mui/material": "7.3.8",
    "@types/jest": "29.5.14",
    "@types/node": "22.x",
    "@types/pg": "8.20.0",
    "@types/react": "19.1.6",
    "@types/react-dom": "19.1.6",
    "@types/sql.js": "1.4.9",
    "@types/vscode": "1.109.0",
    "@types/ws": "8.18.1",
    "copy-webpack-plugin": "14.0.0",
    "jest": "29.7.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "ts-jest": "29.3.4",
    "ts-loader": "9.5.4",
    "webpack": "5.104.1",
    "webpack-cli": "6.0.1"
  }
}
