{
  "name": "anytime-trail",
  "displayName": "%displayName%",
  "description": "%description%",
  "version": "0.3.0",
  "license": "MIT",
  "publisher": "anytime-trial",
  "repository": {
    "type": "git",
    "url": "https://github.com/anytime-trial/anytime-markdown.git"
  },
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "SCM Providers"
  ],
  "keywords": [
    "git",
    "repository",
    "staging",
    "timeline",
    "graph"
  ],
  "activationEvents": [
    "workspaceContains:**/.git/HEAD",
    "onView:anytimeTrail.specDocs",
    "onView:anytimeTrail.changes",
    "onView:anytimeTrail.graph",
    "onView:anytimeTrail.timeline",
    "onCommand:anytime-trail.c4Import",
    "onCommand:anytime-trail.c4Analyze",
    "onCommand:anytime-trail.c4Export",
    "onCommand:anytime-trail.c4View",
    "onCommand:anytime-trail.dsmAnalyze",
    "onView:anytimeTrail.dashboard",
    "onView:anytimeTrail.c4Elements"
  ],
  "icon": "images/camel_git.png",
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "anytimeTrail",
          "title": "%viewsContainer.title%",
          "icon": "images/git-activitybar.svg"
        }
      ]
    },
    "views": {
      "anytimeTrail": [
        {
          "id": "anytimeTrail.dashboard",
          "name": "Dashboard"
        },
        {
          "id": "anytimeTrail.c4Elements",
          "name": "%view.c4Elements%"
        },
        {
          "id": "anytimeTrail.specDocs",
          "name": "%view.specDocs%"
        },
        {
          "id": "anytimeTrail.changes",
          "name": "%view.changes%"
        },
        {
          "id": "anytimeTrail.graph",
          "name": "%view.graph%"
        },
        {
          "id": "anytimeTrail.timeline",
          "name": "Timeline"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "anytimeTrail.specDocs",
        "contents": "%viewsWelcome.specDocs%",
        "when": "!anytimeTrail.specDocsHasRoot"
      },
      {
        "view": "anytimeTrail.changes",
        "contents": "%viewsWelcome.changes%"
      },
      {
        "view": "anytimeTrail.timeline",
        "contents": "No items."
      },
      {
        "view": "anytimeTrail.graph",
        "contents": "No items."
      },
      {
        "view": "anytimeTrail.c4Elements",
        "contents": "%viewsWelcome.c4Elements%",
        "when": "!anytimeTrail.c4ModelLoaded"
      }
    ],
    "commands": [
      {
        "command": "anytime-trail.specDocsOpenFolder",
        "title": "%command.specDocsOpenFolder%",
        "icon": "$(folder-opened)"
      },
      {
        "command": "anytime-trail.specDocsCloneRepo",
        "title": "%command.specDocsCloneRepo%",
        "icon": "$(repo-clone)"
      },
      {
        "command": "anytime-trail.specDocsClose",
        "title": "%command.specDocsClose%",
        "icon": "$(close)"
      },
      {
        "command": "anytime-trail.specDocsRefresh",
        "title": "%command.specDocsRefresh%",
        "icon": "$(refresh)"
      },
      {
        "command": "anytime-trail.toggleMdOnly",
        "title": "%command.toggleMdOnly%",
        "icon": "$(filter)"
      },
      {
        "command": "anytime-trail.switchBranch",
        "title": "%command.switchBranch%",
        "icon": "$(git-branch)"
      },
      {
        "command": "anytime-trail.specDocsCreateFile",
        "title": "%command.specDocsCreateFile%",
        "icon": "$(new-file)"
      },
      {
        "command": "anytime-trail.specDocsCreateFolder",
        "title": "%command.specDocsCreateFolder%",
        "icon": "$(new-folder)"
      },
      {
        "command": "anytime-trail.specDocsDelete",
        "title": "%command.specDocsDelete%",
        "icon": "$(trash)"
      },
      {
        "command": "anytime-trail.specDocsRename",
        "title": "%command.specDocsRename%"
      },
      {
        "command": "anytime-trail.specDocsRemoveRoot",
        "title": "%command.specDocsRemoveRoot%",
        "icon": "$(close)"
      },
      {
        "command": "anytime-trail.specDocsCopyPath",
        "title": "%command.specDocsCopyPath%"
      },
      {
        "command": "anytime-trail.specDocsCopyFileName",
        "title": "%command.specDocsCopyFileName%"
      },
      {
        "command": "anytime-trail.specDocsImportFiles",
        "title": "%command.specDocsImportFiles%",
        "icon": "$(file-add)"
      },
      {
        "command": "anytime-trail.specDocsCut",
        "title": "%command.specDocsCut%"
      },
      {
        "command": "anytime-trail.specDocsCopy",
        "title": "%command.specDocsCopy%"
      },
      {
        "command": "anytime-trail.specDocsPaste",
        "title": "%command.specDocsPaste%"
      },
      {
        "command": "anytime-trail.graphRefresh",
        "title": "%command.graphRefresh%",
        "icon": "$(refresh)"
      },
      {
        "command": "anytime-trail.changesRefresh",
        "title": "%command.changesRefresh%",
        "icon": "$(refresh)"
      },
      {
        "command": "anytime-trail.stageFile",
        "title": "%command.stageFile%",
        "icon": "$(add)"
      },
      {
        "command": "anytime-trail.unstageFile",
        "title": "%command.unstageFile%",
        "icon": "$(remove)"
      },
      {
        "command": "anytime-trail.stageAll",
        "title": "%command.stageAll%",
        "icon": "$(add)"
      },
      {
        "command": "anytime-trail.unstageAll",
        "title": "%command.unstageAll%",
        "icon": "$(close-all)"
      },
      {
        "command": "anytime-trail.discardAll",
        "title": "%command.discardAll%",
        "icon": "$(discard)"
      },
      {
        "command": "anytime-trail.discardChanges",
        "title": "%command.discardChanges%",
        "icon": "$(discard)"
      },
      {
        "command": "anytime-trail.commitChanges",
        "title": "%command.commitChanges%"
      },
      {
        "command": "anytime-trail.pushChanges",
        "title": "%command.pushChanges%"
      },
      {
        "command": "anytime-trail.syncChanges",
        "title": "%command.syncChanges%",
        "icon": "$(sync)"
      },
      {
        "command": "anytime-trail.specDocsOpenFile",
        "title": "Open File"
      },
      {
        "command": "anytime-trail.changesOpenFile",
        "title": "Open Changes"
      },
      {
        "command": "anytime-trail.compareWithCommit",
        "title": "%command.compareWithCommit%"
      },
      {
        "command": "anytime-trail.c4Import",
        "title": "%command.c4Import%",
        "icon": "$(file-code)"
      },
      {
        "command": "anytime-trail.c4Analyze",
        "title": "%command.c4Analyze%",
        "icon": "$(graph)"
      },
      {
        "command": "anytime-trail.c4Export",
        "title": "%command.c4Export%",
        "icon": "$(export)"
      },
      {
        "command": "anytime-trail.c4View",
        "title": "%command.c4View%",
        "icon": "$(open-preview)"
      },
      {
        "command": "anytime-trail.dsmAnalyze",
        "title": "%command.dsmAnalyze%",
        "icon": "$(graph)"
      },
      {
        "command": "anytime-trail.loadCoverage",
        "title": "Load Coverage",
        "icon": "$(beaker)"
      },
      {
        "command": "anytime-trail.runE2eTest",
        "title": "E2Eテスト実行",
        "icon": "$(play)"
      },
      {
        "command": "anytime-trail.runCoverageTest",
        "title": "テスト実行（カバレッジ付き）",
        "icon": "$(beaker)"
      },
      {
        "command": "anytime-trail.openTrailViewer",
        "title": "Open Trail Viewer",
        "category": "Anytime Trail",
        "icon": "$(browser)"
      },
      {
        "command": "anytime-trail.importTrailData",
        "title": "Import JSONL Logs",
        "category": "Anytime Trail",
        "icon": "$(database)"
      }
    ],
    "submenus": [
      {
        "id": "anytimeTrail.changesMore",
        "label": "More Actions...",
        "icon": "$(ellipsis)"
      }
    ],
    "menus": {
      "anytimeTrail.changesMore": [
        {
          "command": "anytime-trail.commitChanges",
          "group": "1_commit@1"
        },
        {
          "command": "anytime-trail.pushChanges",
          "group": "1_commit@2"
        }
      ],
      "view/title": [
        {
          "command": "anytime-trail.toggleMdOnly",
          "when": "view == anytimeTrail.specDocs",
          "group": "navigation@2"
        },
        {
          "command": "anytime-trail.specDocsCreateFile",
          "when": "view == anytimeTrail.specDocs && anytimeTrail.specDocsHasRoot",
          "group": "navigation@3"
        },
        {
          "command": "anytime-trail.specDocsCreateFolder",
          "when": "view == anytimeTrail.specDocs && anytimeTrail.specDocsHasRoot",
          "group": "navigation@4"
        },
        {
          "command": "anytime-trail.specDocsRefresh",
          "when": "view == anytimeTrail.specDocs && anytimeTrail.specDocsHasRoot",
          "group": "navigation@5"
        },
        {
          "command": "anytime-trail.specDocsOpenFolder",
          "when": "view == anytimeTrail.specDocs && anytimeTrail.specDocsHasRoot",
          "group": "navigation@6"
        },
        {
          "command": "anytime-trail.specDocsCloneRepo",
          "when": "view == anytimeTrail.specDocs && anytimeTrail.specDocsHasRoot",
          "group": "navigation@7"
        },
        {
          "command": "anytime-trail.graphRefresh",
          "when": "view == anytimeTrail.graph",
          "group": "navigation@1"
        },
        {
          "command": "anytime-trail.changesRefresh",
          "when": "view == anytimeTrail.changes",
          "group": "navigation@1"
        },
        {
          "submenu": "anytimeTrail.changesMore",
          "when": "view == anytimeTrail.changes",
          "group": "navigation@2"
        },
        {
          "command": "anytime-trail.openTrailViewer",
          "when": "view == anytimeTrail.dashboard",
          "group": "navigation@1"
        },
        {
          "command": "anytime-trail.importTrailData",
          "when": "view == anytimeTrail.dashboard",
          "group": "navigation@2"
        },
        {
          "command": "anytime-trail.c4View",
          "when": "view == anytimeTrail.c4Elements",
          "group": "navigation@1"
        }
      ],
      "view/item/context": [
        {
          "command": "anytime-trail.specDocsCreateFile",
          "when": "view == anytimeTrail.specDocs && viewItem == folder",
          "group": "1_new@1"
        },
        {
          "command": "anytime-trail.specDocsCreateFolder",
          "when": "view == anytimeTrail.specDocs && viewItem == folder",
          "group": "1_new@2"
        },
        {
          "command": "anytime-trail.specDocsImportFiles",
          "when": "view == anytimeTrail.specDocs && viewItem == folder",
          "group": "1_new@3"
        },
        {
          "command": "anytime-trail.specDocsCreateFile",
          "when": "view == anytimeTrail.specDocs && viewItem == specDocsRoot",
          "group": "1_new@1"
        },
        {
          "command": "anytime-trail.specDocsCreateFolder",
          "when": "view == anytimeTrail.specDocs && viewItem == specDocsRoot",
          "group": "1_new@2"
        },
        {
          "command": "anytime-trail.specDocsImportFiles",
          "when": "view == anytimeTrail.specDocs && viewItem == specDocsRoot",
          "group": "1_new@3"
        },
        {
          "command": "anytime-trail.specDocsPaste",
          "when": "view == anytimeTrail.specDocs && viewItem == specDocsRoot",
          "group": "1_new@4"
        },
        {
          "command": "anytime-trail.specDocsCut",
          "when": "view == anytimeTrail.specDocs && viewItem != specDocsRoot",
          "group": "2_clipboard@1"
        },
        {
          "command": "anytime-trail.specDocsCopy",
          "when": "view == anytimeTrail.specDocs && viewItem != specDocsRoot",
          "group": "2_clipboard@2"
        },
        {
          "command": "anytime-trail.specDocsPaste",
          "when": "view == anytimeTrail.specDocs && viewItem != specDocsRoot",
          "group": "2_clipboard@3"
        },
        {
          "command": "anytime-trail.specDocsCopyPath",
          "when": "view == anytimeTrail.specDocs && viewItem != specDocsRoot",
          "group": "3_path@1"
        },
        {
          "command": "anytime-trail.specDocsCopyFileName",
          "when": "view == anytimeTrail.specDocs && viewItem != specDocsRoot",
          "group": "3_path@2"
        },
        {
          "command": "anytime-trail.specDocsRename",
          "when": "view == anytimeTrail.specDocs && viewItem != specDocsRoot",
          "group": "4_modify@1"
        },
        {
          "command": "anytime-trail.specDocsDelete",
          "when": "view == anytimeTrail.specDocs && viewItem != specDocsRoot",
          "group": "4_modify@2"
        },
        {
          "command": "anytime-trail.switchBranch",
          "when": "view == anytimeTrail.specDocs && viewItem == specDocsRoot",
          "group": "3_root@1"
        },
        {
          "command": "anytime-trail.specDocsRemoveRoot",
          "when": "view == anytimeTrail.specDocs && viewItem == specDocsRoot",
          "group": "3_root@2"
        },
        {
          "command": "anytime-trail.discardAll",
          "when": "view == anytimeTrail.changes && viewItem == changesGroupChanges",
          "group": "inline@1"
        },
        {
          "command": "anytime-trail.stageAll",
          "when": "view == anytimeTrail.changes && viewItem == changesGroupChanges",
          "group": "inline@2"
        },
        {
          "command": "anytime-trail.unstageAll",
          "when": "view == anytimeTrail.changes && viewItem == changesGroupStaged",
          "group": "inline@1"
        },
        {
          "command": "anytime-trail.stageFile",
          "when": "view == anytimeTrail.changes && viewItem == changesFileUnstaged",
          "group": "inline@2"
        },
        {
          "command": "anytime-trail.discardChanges",
          "when": "view == anytimeTrail.changes && viewItem == changesFileUnstaged",
          "group": "inline@1"
        },
        {
          "command": "anytime-trail.unstageFile",
          "when": "view == anytimeTrail.changes && viewItem == changesFileStaged",
          "group": "inline@1"
        },
        {
          "command": "anytime-trail.c4View",
          "when": "view == anytimeTrail.c4Elements && viewItem == c4Root",
          "group": "0_view@1"
        },
        {
          "command": "anytime-trail.c4Analyze",
          "when": "view == anytimeTrail.c4Elements && viewItem == c4Root",
          "group": "1_c4@1"
        },
        {
          "command": "anytime-trail.c4Export",
          "when": "view == anytimeTrail.c4Elements && viewItem == c4Root",
          "group": "1_c4@2"
        },
        {
          "command": "anytime-trail.c4Import",
          "when": "view == anytimeTrail.c4Elements && viewItem == c4Root",
          "group": "1_c4@3"
        },
        {
          "command": "anytime-trail.runE2eTest",
          "when": "view == anytimeTrail.c4Elements && viewItem == c4Level.c1",
          "group": "1_test@1"
        },
        {
          "command": "anytime-trail.runCoverageTest",
          "when": "view == anytimeTrail.c4Elements && viewItem == c4Level.c4",
          "group": "1_test@1"
        }
      ]
    },
    "keybindings": [
      {
        "command": "anytime-trail.specDocsCut",
        "key": "ctrl+x",
        "mac": "cmd+x",
        "when": "focusedView == anytimeTrail.specDocs"
      },
      {
        "command": "anytime-trail.specDocsCopy",
        "key": "ctrl+c",
        "mac": "cmd+c",
        "when": "focusedView == anytimeTrail.specDocs"
      },
      {
        "command": "anytime-trail.specDocsPaste",
        "key": "ctrl+v",
        "mac": "cmd+v",
        "when": "focusedView == anytimeTrail.specDocs"
      }
    ],
    "configuration": {
      "title": "Anytime Trail",
      "properties": {
        "anytimeTrail.c4.analyzeExcludePatterns": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            ".worktrees",
            ".vscode-test",
            "__tests__"
          ],
          "markdownDescription": "%config.c4AnalyzeExcludePatterns%"
        },
        "anytimeTrail.c4.modelPath": {
          "type": "string",
          "default": ".vscode/c4-model.json",
          "markdownDescription": "%config.c4ModelPath%"
        },
        "anytimeTrail.docsPath": {
          "type": "string",
          "default": "",
          "markdownDescription": "Absolute path to the documentation directory for C4 document links. When set, Markdown files with `c4Scope` frontmatter are indexed and shown in the C4 viewer."
        },
        "anytimeTrail.server.enabled": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "Enable the C4 data server for external web app access"
        },
        "anytimeTrail.server.port": {
          "type": "number",
          "default": 19840,
          "markdownDescription": "Port number for the C4 data server"
        },
        "anytimeTrail.coverage.path": {
          "type": "string",
          "default": "",
          "markdownDescription": "Path to `coverage-final.json` (relative to workspace root). When set, file changes are watched and coverage is auto-updated."
        },
        "anytimeTrail.test.e2eCommand": {
          "type": "string",
          "default": "cd packages/web-app && npm run e2e",
          "markdownDescription": "Command to run E2E tests (executed in VS Code terminal)."
        },
        "anytimeTrail.test.coverageCommand": {
          "type": "string",
          "default": "npx jest --coverage --maxWorkers=1",
          "markdownDescription": "Command to run tests with coverage (executed in VS Code terminal). The generated `coverage-final.json` is auto-detected by the coverage watcher."
        },
        "anytimeTrail.trailServer.port": {
          "type": "number",
          "default": 19841,
          "description": "Port number for the Trail Viewer server"
        },
        "anytimeTrail.coverage.historyLimit": {
          "type": "number",
          "default": 50,
          "minimum": 1,
          "maximum": 500,
          "markdownDescription": "Maximum number of coverage history snapshots to keep."
        }
      }
    }
  },
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": "limited",
      "description": "Git operations and file system access require workspace trust.",
      "restrictedConfigurations": []
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "vscode:uninstall": "node ./dist/uninstall.js",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "test": "jest --maxWorkers=1"
  },
  "dependencies": {
    "@anytime-markdown/c4-kernel": "*",
    "@anytime-markdown/c4-viewer": "*",
    "@anytime-markdown/graph-core": "*",
    "@anytime-markdown/trail-core": "*",
    "sql.js": "1.12.0",
    "typescript": "5.9.3",
    "ws": "8.18.2"
  },
  "devDependencies": {
    "@types/sql.js": "1.4.9",
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.0",
    "@mui/icons-material": "7.3.8",
    "@mui/material": "7.3.8",
    "@types/jest": "29.5.14",
    "@types/node": "22.x",
    "@types/react": "19.1.6",
    "@types/react-dom": "19.1.6",
    "@types/vscode": "1.109.0",
    "@types/ws": "8.18.1",
    "jest": "29.7.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "ts-jest": "29.3.4",
    "ts-loader": "9.5.4",
    "copy-webpack-plugin": "12.0.2",
    "webpack": "5.104.1",
    "webpack-cli": "6.0.1"
  }
}
