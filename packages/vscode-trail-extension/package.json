{
  "name": "anytime-trail",
  "displayName": "%displayName%",
  "description": "%description%",
  "version": "0.13.0",
  "license": "MIT",
  "publisher": "anytime-trial",
  "repository": {
    "type": "git",
    "url": "https://github.com/anytime-trial/anytime-markdown.git"
  },
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Visualization"
  ],
  "keywords": [
    "c4",
    "architecture",
    "trail",
    "dashboard",
    "analysis"
  ],
  "activationEvents": [
    "onCommand:anytime-trail.c4Analyze",
    "onCommand:anytime-trail.c4View",
    "onCommand:anytime-trail.dsmAnalyze",
    "onView:anytimeTrail.database",
    "onView:anytimeTrail.c4Elements"
  ],
  "icon": "images/anytime-control-256.png",
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "anytimeTrail",
          "title": "%viewsContainer.title%",
          "icon": "images/trail_activitybar_icon.svg"
        }
      ]
    },
    "views": {
      "anytimeTrail": [
        {
          "id": "anytimeTrail.aiNote",
          "name": "%view.aiNote%"
        },
        {
          "id": "anytimeTrail.dashboard",
          "name": "%view.dashboard%"
        },
        {
          "id": "anytimeTrail.database",
          "name": "%view.database%"
        },
        {
          "id": "anytimeTrail.c4Elements",
          "name": "%view.c4Elements%"
        },
        {
          "id": "anytimeTrail.aiMemory",
          "name": "Memory"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "anytimeTrail.aiNote",
        "contents": "%viewsWelcome.aiNote%"
      },
      {
        "view": "anytimeTrail.dashboard",
        "contents": "%viewsWelcome.dashboard%"
      },
      {
        "view": "anytimeTrail.c4Elements",
        "contents": "%viewsWelcome.c4Elements%",
        "when": "!anytimeTrail.c4ModelLoaded"
      }
    ],
    "commands": [
      {
        "command": "anytime-trail.openContext",
        "title": "%command.openContext%",
        "icon": "$(note)"
      },
      {
        "command": "anytime-trail.openNoteSkill",
        "title": "%command.openNoteSkill%",
        "icon": "$(book)"
      },
      {
        "command": "anytime-trail.addNotePage",
        "title": "%command.addNotePage%",
        "icon": "$(add)"
      },
      {
        "command": "anytime-trail.deleteNotePage",
        "title": "%command.deleteNotePage%",
        "icon": "$(trash)"
      },
      {
        "command": "anytime-trail.openNotePage",
        "title": "%command.openNotePage%"
      },
      {
        "command": "anytime-trail.clearContext",
        "title": "%command.clearContext%",
        "icon": "$(trash)"
      },
      {
        "command": "anytime-trail.copyContextPath",
        "title": "%command.copyContextPath%",
        "icon": "$(clippy)"
      },
      {
        "command": "anytime-trail.c4Analyze",
        "title": "%command.c4Analyze%",
        "icon": "$(symbol-class)"
      },
      {
        "command": "anytime-trail.c4View",
        "title": "%command.c4View%",
        "icon": "$(open-preview)"
      },
      {
        "command": "anytime-trail.dsmAnalyze",
        "title": "%command.dsmAnalyze%",
        "icon": "$(graph)"
      },
      {
        "command": "anytime-trail.loadCoverage",
        "title": "Load Coverage",
        "icon": "$(beaker)"
      },
      {
        "command": "anytime-trail.runE2eTest",
        "title": "E2Eテスト実行",
        "icon": "$(play)"
      },
      {
        "command": "anytime-trail.runCoverageTest",
        "title": "テスト実行（カバレッジ付き）",
        "icon": "$(beaker)"
      },
      {
        "command": "anytime-trail.openTrailViewer",
        "title": "%command.openTrailViewer%",
        "category": "Anytime Trail",
        "icon": "$(graph-line)"
      },
      {
        "command": "anytime-trail.restoreBackup",
        "title": "%command.restoreBackup%",
        "category": "Anytime Trail",
        "icon": "$(discard)"
      },
      {
        "command": "anytime-trail.importTrailData",
        "title": "Refresh Trail Data",
        "category": "Anytime Trail",
        "icon": "$(refresh)"
      },
      {
        "command": "anytime-trail.syncToRemote",
        "title": "Sync to Remote DB",
        "category": "Anytime Trail",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "anytime-trail.syncToSupabase",
        "title": "同期",
        "category": "Anytime Trail"
      },
      {
        "command": "anytime-trail.reconnectSupabase",
        "title": "再接続",
        "category": "Anytime Trail"
      },
      {
        "command": "anytime-trail.aiMemoryRefresh",
        "title": "%command.aiMemoryRefresh%",
        "icon": "$(refresh)"
      },
      {
        "command": "anytime-trail.generateCodeGraph",
        "title": "Generate Code Graph",
        "category": "Anytime Trail",
        "icon": "$(graph)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "anytime-trail.openNoteSkill",
          "when": "view == anytimeTrail.aiNote",
          "group": "navigation@1"
        },
        {
          "command": "anytime-trail.addNotePage",
          "when": "view == anytimeTrail.aiNote",
          "group": "navigation@2"
        },
        {
          "command": "anytime-trail.clearContext",
          "when": "view == anytimeTrail.aiNote",
          "group": "navigation@3"
        },
        {
          "command": "anytime-trail.copyContextPath",
          "when": "view == anytimeTrail.aiNote",
          "group": "navigation@3"
        },
        {
          "command": "anytime-trail.c4Analyze",
          "when": "view == anytimeTrail.c4Elements",
          "group": "navigation@1"
        },
        {
          "command": "anytime-trail.aiMemoryRefresh",
          "when": "view == anytimeTrail.aiMemory",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "anytime-trail.deleteNotePage",
          "when": "view == anytimeTrail.aiNote && viewItem == noteItem",
          "group": "inline"
        },
        {
          "command": "anytime-trail.runE2eTest",
          "when": "view == anytimeTrail.c4Elements && viewItem == c4Level.c1",
          "group": "1_test@1"
        },
        {
          "command": "anytime-trail.runCoverageTest",
          "when": "view == anytimeTrail.c4Elements && viewItem == c4Level.c4",
          "group": "1_test@1"
        },
        {
          "command": "anytime-trail.importTrailData",
          "when": "view == anytimeTrail.database && viewItem == sqliteDb",
          "group": "inline"
        },
        {
          "command": "anytime-trail.syncToSupabase",
          "when": "view == anytimeTrail.database && viewItem == supabaseDb",
          "group": "inline"
        },
        {
          "command": "anytime-trail.reconnectSupabase",
          "when": "view == anytimeTrail.database && viewItem == supabaseDb",
          "group": "inline"
        }
      ]
    },
    "configuration": {
      "title": "Anytime Trail",
      "properties": {
        "anytimeTrail.c4.analyzeExcludePatterns": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            ".worktrees",
            ".vscode-test",
            "__tests__"
          ],
          "markdownDescription": "%config.c4AnalyzeExcludePatterns%"
        },
        "anytimeTrail.docsPath": {
          "type": "string",
          "default": "",
          "markdownDescription": "Absolute path to the documentation directory for C4 document links. When set, Markdown files with `c4Scope` frontmatter are indexed and shown in the C4 viewer."
        },
        "anytimeTrail.codeGraph.outputDir": {
          "type": "string",
          "default": "${workspaceFolder}/.vscode/graphify-out",
          "markdownDescription": "コードグラフの出力先ディレクトリ。`${workspaceFolder}` を使用可能。"
        },
        "anytimeTrail.codeGraph.repositories": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "${workspaceFolder}"
          ],
          "markdownDescription": "解析対象リポジトリのパスリスト。絶対パスまたは `${workspaceFolder}` を指定する。表示名はパスの末尾フォルダ名が使用される。"
        },
        "anytimeTrail.codeGraph.autoRefresh": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "拡張機能起動時にコードグラフを自動生成する。"
        },
        "anytimeTrail.coverage.path": {
          "type": "string",
          "default": "",
          "markdownDescription": "Path to `coverage-final.json` (relative to workspace root). When set, file changes are watched and coverage is auto-updated."
        },
        "anytimeTrail.test.e2eCommand": {
          "type": "string",
          "default": "cd packages/web-app && npm run e2e",
          "markdownDescription": "Command to run E2E tests (executed in VS Code terminal)."
        },
        "anytimeTrail.test.coverageCommand": {
          "type": "string",
          "default": "npx jest --coverage --maxWorkers=1",
          "markdownDescription": "Command to run tests with coverage (executed in VS Code terminal). The generated `coverage-final.json` is auto-detected by the coverage watcher."
        },
        "anytimeTrail.trailServer.port": {
          "type": "number",
          "default": 19841,
          "description": "Port number for the Trail Viewer server"
        },
        "anytimeTrail.coverage.historyLimit": {
          "type": "number",
          "default": 50,
          "minimum": 1,
          "maximum": 500,
          "markdownDescription": "Maximum number of coverage history snapshots to keep."
        },
        "anytimeTrail.remote.provider": {
          "type": "string",
          "enum": [
            "none",
            "supabase",
            "postgres"
          ],
          "default": "none",
          "markdownDescription": "Remote database provider for Trail data sync. `none` disables sync."
        },
        "anytimeTrail.remote.supabaseUrl": {
          "type": "string",
          "default": "",
          "markdownDescription": "Supabase project URL (e.g. `https://xxx.supabase.co`)"
        },
        "anytimeTrail.remote.supabaseAnonKey": {
          "type": "string",
          "default": "",
          "markdownDescription": "Supabase anon key for Trail data sync"
        },
        "anytimeTrail.remote.postgresUrl": {
          "type": "string",
          "default": "",
          "markdownDescription": "PostgreSQL connection string (e.g. `postgres://user:pass@host:5432/db`)"
        },
        "anytimeTrail.database.storagePath": {
          "type": "string",
          "default": "",
          "markdownDescription": "%config.database.storagePath%"
        },
        "anytimeTrail.database.backupGenerations": {
          "type": "number",
          "default": 1,
          "minimum": 1,
          "maximum": 10,
          "markdownDescription": "%config.database.backupGenerations%"
        },
        "anytimeTrail.claudeStatus.directory": {
          "type": "string",
          "default": "",
          "markdownDescription": "%config.claudeStatus.directory%"
        },
        "anytimeTrail.budget.dailyLimitTokens": {
          "type": [
            "number",
            "null"
          ],
          "default": null,
          "markdownDescription": "日次トークン上限。`null` で無効。"
        },
        "anytimeTrail.budget.sessionLimitTokens": {
          "type": [
            "number",
            "null"
          ],
          "default": null,
          "markdownDescription": "セッションあたりのトークン上限。`null` で無効。"
        },
        "anytimeTrail.budget.alertThresholdPct": {
          "type": "number",
          "default": 80,
          "minimum": 1,
          "maximum": 100,
          "markdownDescription": "上限に対する警告閾値（%）。"
        }
      }
    }
  },
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": "limited",
      "description": "Git operations and file system access require workspace trust.",
      "restrictedConfigurations": []
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "test": "jest --maxWorkers=1"
  },
  "dependencies": {
    "@anytime-markdown/graph-core": "*",
    "@anytime-markdown/trail-core": "*",
    "@anytime-markdown/vscode-common": "*",
    "@supabase/supabase-js": "2.103.0",
    "graphology": "0.26.0",
    "graphology-communities-louvain": "2.0.2",
    "graphology-layout": "0.6.1",
    "graphology-layout-forceatlas2": "0.10.1",
    "graphology-shortest-path": "2.1.0",
    "pg": "8.20.0",
    "sql.js": "1.12.0",
    "typescript": "5.9.3",
    "ws": "8.18.2"
  },
  "devDependencies": {
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.0",
    "@mui/icons-material": "7.3.8",
    "@mui/material": "7.3.8",
    "@types/jest": "29.5.14",
    "@types/node": "22.x",
    "@types/pg": "8.20.0",
    "@types/react": "19.1.6",
    "@types/react-dom": "19.1.6",
    "@types/sql.js": "1.4.9",
    "@types/vscode": "1.109.0",
    "@types/ws": "8.18.1",
    "copy-webpack-plugin": "14.0.0",
    "jest": "29.7.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "ts-jest": "29.3.4",
    "ts-loader": "9.5.4",
    "webpack": "5.104.1",
    "webpack-cli": "6.0.1"
  }
}
