{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2023", "DOM", "DOM.Iterable", "webworker"],
    "types": ["@serwist/next/typings", "jest"],
    "plugins": [
      {
        "name": "next"
      }
    ],
    "incremental": true,
    "isolatedModules": true,
    "noEmit": true,
    "allowJs": true,
    "resolveJsonModule": true,
    "jsx": "preserve",
    "paths": {
      "@/*": ["../markdown-core/src/*"],
      "@anytime-markdown/markdown-core/src/*": ["../markdown-core/src/*"],
      "@anytime-markdown/markdown-core": ["../markdown-core/src/index.ts"],
      "@anytime-markdown/graph-core": ["../graph-core/src/index.ts"],
      "@anytime-markdown/graph-core/*": ["../graph-core/src/*"]
    }
  },
  "include": [
    "src/**/*",
    "next-env.d.ts",
    ".next/types/**/*.ts",
    "../markdown-core/src/md.d.ts",
    "../markdown-core/src/types/vscode.d.ts",
    "../markdown-core/src/plotly-gl3d.d.ts"
  ],
  "exclude": [
    "node_modules",
    "public/sw.js"
  ]
}
