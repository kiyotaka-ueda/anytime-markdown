{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable", "webworker"],
    "types": ["@serwist/next/typings", "jest"],
    "plugins": [
      {
        "name": "next"
      }
    ],
    "incremental": true,
    "isolatedModules": true,
    "noEmit": true,
    "allowJs": true,
    "resolveJsonModule": true,
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {
      "@/*": ["../editor-core/src/*"],
      "@anytime-markdown/editor-core/src/*": ["../editor-core/src/*"],
      "@anytime-markdown/editor-core": ["../editor-core/src/index.ts"]
    }
  },
  "include": [
    "src/**/*",
    "next-env.d.ts",
    ".next/types/**/*.ts",
    "../editor-core/src/md.d.ts",
    "../editor-core/src/types/gif.js.d.ts"
  ],
  "exclude": [
    "node_modules",
    "public/sw.js"
  ]
}
