# Google Analytics 測定 ID（未設定時は GA スクリプトを出力しない）
NEXT_PUBLIC_GA_ID=

# Readonly モード切替ボタンの表示（1 で有効）
NEXT_PUBLIC_SHOW_READONLY_MODE=

# テーマプリセット切替の表示（1 で有効、未設定または 0 で非表示）
NEXT_PUBLIC_SHOW_THEME_PRESET=

# Graph ページリンクの表示（1 で有効、未設定または 0 で非表示）
NEXT_PUBLIC_SHOW_GRAPH=

# Spotify ページリンクの表示（1 で有効、未設定または 0 で非表示）
NEXT_PUBLIC_SHOW_SPOTIFY=

# S3 ドキュメントビューア（サーバーサイド専用）
ANYTIME_AWS_REGION=ap-northeast-1
ANYTIME_AWS_ACCESS_KEY_ID=
ANYTIME_AWS_SECRET_ACCESS_KEY=
S3_DOCS_BUCKET=
S3_DOCS_PREFIX=docs/

# CloudFront CDN（未設定時は S3 SDK に直接アクセス）
CLOUDFRONT_DOCS_URL=

# ドキュメント編集ページの有効化（true で /docs/edit にアクセス可能、未設定時はリダイレクト・リンク非表示）
NEXT_PUBLIC_ENABLE_DOCS_EDIT=true

# CMS Basic 認証（アップロード・削除操作用）
CMS_BASIC_USER=admin
CMS_BASIC_PASSWORD=anytime

# GitHub 連携の有効化（1 で有効、未設定または 0 で無効）
NEXT_PUBLIC_ENABLE_GITHUB=

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
# next-auth v5 では AUTH_SECRET を推奨（NEXTAUTH_SECRET も後方互換で動作）
AUTH_SECRET=

# 無制限表示モード（1 で有効: 90D表示・tracesは全セッション表示、未設定または0で制限あり）
NEXT_PUBLIC_SHOW_UNLIMITED=

# Supabase Trail Viewer（リモート DB 読み取り、未設定時はローカルサーバーモード）
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ドキュメントリポジトリ（GitHub）
# "owner/repo" 形式または "https://github.com/owner/repo" 形式 — 未設定時は Documents セクション非表示
DOCS_GITHUB_REPO=
# PAT（private repo 用、public repo なら省略可）
DOCS_GITHUB_TOKEN=

# Spotify OAuth
# Spotify Developer Dashboard (https://developer.spotify.com/dashboard) でアプリを作成し取得
# Redirect URI として http://localhost:3000/api/auth/callback/spotify を登録すること
SPOTIFY_CLIENT_ID=(必須)
SPOTIFY_CLIENT_SECRET=(必須)
# プレイリストページをヘッダーに表示（1 で有効）
NEXT_PUBLIC_SHOW_PLAYLIST=

# The Guardian News API（未設定時は "test" キーで動作、本番では登録キーを推奨）
# https://open-platform.theguardian.com/access/ で無料取得可
GUARDIAN_API_KEY=

# YouTube Data API v3
# Google Cloud Console (https://console.cloud.google.com/) で取得
# YouTube Data API v3 を有効化し、API キーと OAuth クライアントを作成すること
# Redirect URI: http://localhost:3000/api/auth/callback/google
YOUTUBE_API_KEY=(必須)
YOUTUBE_CLIENT_ID=(必須)
YOUTUBE_CLIENT_SECRET=(必須)
