# Google Analytics 測定 ID（未設定時は GA スクリプトを出力しない）
NEXT_PUBLIC_GA_ID=

# Readonly モード切替ボタンの表示（1 で有効）
NEXT_PUBLIC_SHOW_READONLY_MODE=

# S3 ドキュメントビューア（サーバーサイド専用）
ANYTIME_AWS_REGION=ap-northeast-1
ANYTIME_AWS_ACCESS_KEY_ID=
ANYTIME_AWS_SECRET_ACCESS_KEY=
S3_DOCS_BUCKET=
S3_DOCS_PREFIX=docs/

# CloudFront CDN（未設定時は S3 SDK に直接アクセス）
CLOUDFRONT_DOCS_URL=

# CMS Basic 認証（アップロード・削除操作用）
CMS_BASIC_USER=admin
CMS_BASIC_PASSWORD=anytime
