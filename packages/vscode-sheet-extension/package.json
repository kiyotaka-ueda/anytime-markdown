{
  "name": "anytime-sheet",
  "displayName": "%displayName%",
  "description": "%description%",
  "version": "0.4.1",
  "license": "MIT",
  "publisher": "anytime-trial",
  "repository": { "type": "git", "url": "https://github.com/anytime-trial/anytime-markdown.git" },
  "engines": { "vscode": "^1.109.0" },
  "icon": "images/anytime-sheet-128.png",
  "categories": ["Visualization"],
  "keywords": ["spreadsheet", "csv", "tsv", "sheet"],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "anytimeSheet",
        "displayName": "%customEditor.displayName%",
        "selector": [{ "filenamePattern": "*.sheet" }],
        "priority": "default"
      },
      {
        "viewType": "anytimeSheet.csv",
        "displayName": "%customEditor.displayName%",
        "selector": [
          { "filenamePattern": "*.csv" },
          { "filenamePattern": "*.tsv" }
        ],
        "priority": "option"
      }
    ],
    "commands": [{ "command": "anytime-sheet.newSheet", "title": "%command.newSheet%" }]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map"
  },
  "devDependencies": {
    "@types/node": "22.x",
    "@types/vscode": "1.109.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "ts-loader": "9.5.4",
    "typescript": "5.9.3",
    "webpack": "5.104.1",
    "webpack-cli": "6.0.1"
  },
  "dependencies": {
    "@anytime-markdown/spreadsheet-core": "*",
    "@anytime-markdown/spreadsheet-viewer": "*",
    "@anytime-markdown/vscode-common": "*",
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.0",
    "@mui/icons-material": "7.3.7",
    "@mui/material": "7.3.7",
    "next-intl": "4.9.1",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  }
}
