{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2023", "DOM"],
    "noEmit": true,
    "isolatedModules": true,
    "declaration": true,
    "jsx": "react-jsx",
    "paths": {
      "@anytime-markdown/trail-core": ["../trail-core/src/index.ts"],
      "@anytime-markdown/trail-core/*": ["../trail-core/src/*/index.ts", "../trail-core/src/*.ts"]
    }
  },
  "include": ["src/**/*"]
}
