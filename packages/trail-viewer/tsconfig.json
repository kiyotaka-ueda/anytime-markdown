{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2023", "DOM"],
    "noEmit": true,
    "isolatedModules": true,
    "declaration": true,
    "jsx": "react-jsx",
    "paths": {
      "@anytime-markdown/graph-core": ["../graph-core/src/index.ts"],
      "@anytime-markdown/graph-core/engine": ["../graph-core/src/engine/index.ts"],
      "@anytime-markdown/graph-core/state": ["../graph-core/src/state/index.ts"],
      "@anytime-markdown/trail-core/c4": ["../trail-core/src/c4/index.ts"],
      "@anytime-markdown/trail-core/domain/metrics": ["../trail-core/src/domain/metrics/index.ts"],
      "@anytime-markdown/trace-core/c4Sequence": ["../trace-core/src/c4Sequence.ts"]
    }
  },
  "include": ["src/**/*"]
}
