{
  "name": "anytime-markdown",
  "displayName": "%displayName%",
  "description": "%description%",
  "version": "0.7.7",
  "license": "MIT",
  "publisher": "anytime-trial",
  "repository": {
    "type": "git",
    "url": "https://github.com/anytime-trial/anytime-markdown.git"
  },
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "sdd",
    "image prompt",
    "markdown",
    "mermaid",
    "plantuml"
  ],
  "activationEvents": [
    "onLanguage:markdown",
    "onView:anytimeMarkdown.specDocs",
    "onView:anytimeMarkdown.changes",
    "onView:anytimeMarkdown.graph"
  ],
  "icon": "images/camel_markdown.png",
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "anytimeMarkdown",
          "title": "%viewsContainer.title%",
          "icon": "images/camel-activitybar.svg"
        }
      ]
    },
    "views": {
      "anytimeMarkdown": [
        {
          "id": "anytimeMarkdown.aiNote",
          "name": "Agent Note",
          "initialSize": 1
        },
        {
          "id": "anytimeMarkdown.aiLog",
          "name": "Agent Log",
          "initialSize": 2
        },
        {
          "id": "anytimeMarkdown.aiMemory",
          "name": "Agent Memory",
          "initialSize": 2
        },
        {
          "id": "anytimeMarkdown.specDocs",
          "name": "%view.specDocs%"
        },
        {
          "id": "anytimeMarkdown.changes",
          "name": "%view.changes%"
        },
        {
          "id": "anytimeMarkdown.graph",
          "name": "%view.graph%"
        },
        {
          "id": "anytimeMarkdown.timeline",
          "name": "Timeline"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "anytimeMarkdown.aiNote",
        "contents": "%viewsWelcome.aiNote%"
      },
      {
        "view": "anytimeMarkdown.specDocs",
        "contents": "%viewsWelcome.specDocs%",
        "when": "!anytimeMarkdown.specDocsHasRoot"
      },
      {
        "view": "anytimeMarkdown.changes",
        "contents": "%viewsWelcome.changes%"
      },
      {
        "view": "anytimeMarkdown.timeline",
        "contents": "No items."
      },
      {
        "view": "anytimeMarkdown.graph",
        "contents": "No items."
      }
    ],
    "commands": [
      {
        "command": "anytime-markdown.openEditorWithFile",
        "title": "%command.openEditorWithFile%"
      },
      {
        "command": "anytime-markdown.compareWithMarkdownEditor",
        "title": "%command.compareWithMarkdownEditor%",
        "enablement": "activeCustomEditorId == anytimeMarkdown"
      },
      {
        "command": "anytime-markdown.insertSectionNumbers",
        "title": "%command.insertSectionNumbers%",
        "icon": "$(list-ordered)"
      },
      {
        "command": "anytime-markdown.removeSectionNumbers",
        "title": "%command.removeSectionNumbers%",
        "icon": "$(list-flat)"
      },
      {
        "command": "anytime-markdown.specDocsOpenFolder",
        "title": "%command.specDocsOpenFolder%",
        "icon": "$(folder-opened)"
      },
      {
        "command": "anytime-markdown.specDocsCloneRepo",
        "title": "%command.specDocsCloneRepo%",
        "icon": "$(repo-clone)"
      },
      {
        "command": "anytime-markdown.specDocsClose",
        "title": "%command.specDocsClose%",
        "icon": "$(close)"
      },
      {
        "command": "anytime-markdown.specDocsRefresh",
        "title": "%command.specDocsRefresh%",
        "icon": "$(refresh)"
      },
      {
        "command": "anytime-markdown.toggleMdOnly",
        "title": "%command.toggleMdOnly%",
        "icon": "$(filter)"
      },
      {
        "command": "anytime-markdown.switchBranch",
        "title": "%command.switchBranch%",
        "icon": "$(git-branch)"
      },
      {
        "command": "anytime-markdown.specDocsCreateFile",
        "title": "%command.specDocsCreateFile%",
        "icon": "$(new-file)"
      },
      {
        "command": "anytime-markdown.specDocsCreateFolder",
        "title": "%command.specDocsCreateFolder%",
        "icon": "$(new-folder)"
      },
      {
        "command": "anytime-markdown.specDocsDelete",
        "title": "%command.specDocsDelete%",
        "icon": "$(trash)"
      },
      {
        "command": "anytime-markdown.specDocsRename",
        "title": "%command.specDocsRename%"
      },
      {
        "command": "anytime-markdown.graphRefresh",
        "title": "%command.graphRefresh%",
        "icon": "$(refresh)"
      },
      {
        "command": "anytime-markdown.changesRefresh",
        "title": "%command.changesRefresh%",
        "icon": "$(refresh)"
      },
      {
        "command": "anytime-markdown.stageFile",
        "title": "%command.stageFile%",
        "icon": "$(add)"
      },
      {
        "command": "anytime-markdown.unstageFile",
        "title": "%command.unstageFile%",
        "icon": "$(remove)"
      },
      {
        "command": "anytime-markdown.stageAll",
        "title": "%command.stageAll%",
        "icon": "$(add)"
      },
      {
        "command": "anytime-markdown.unstageAll",
        "title": "%command.unstageAll%",
        "icon": "$(close-all)"
      },
      {
        "command": "anytime-markdown.discardAll",
        "title": "%command.discardAll%",
        "icon": "$(discard)"
      },
      {
        "command": "anytime-markdown.discardChanges",
        "title": "%command.discardChanges%",
        "icon": "$(discard)"
      },
      {
        "command": "anytime-markdown.commitChanges",
        "title": "%command.commitChanges%"
      },
      {
        "command": "anytime-markdown.pushChanges",
        "title": "%command.pushChanges%"
      },
      {
        "command": "anytime-markdown.specDocsRemoveRoot",
        "title": "%command.specDocsRemoveRoot%",
        "icon": "$(close)"
      },
      {
        "command": "anytime-markdown.specDocsCopyPath",
        "title": "%command.specDocsCopyPath%"
      },
      {
        "command": "anytime-markdown.specDocsCopyFileName",
        "title": "%command.specDocsCopyFileName%"
      },
      {
        "command": "anytime-markdown.specDocsImportFiles",
        "title": "%command.specDocsImportFiles%",
        "icon": "$(file-add)"
      },
      {
        "command": "anytime-markdown.specDocsCut",
        "title": "%command.specDocsCut%"
      },
      {
        "command": "anytime-markdown.specDocsCopy",
        "title": "%command.specDocsCopy%"
      },
      {
        "command": "anytime-markdown.specDocsPaste",
        "title": "%command.specDocsPaste%"
      },
      {
        "command": "anytime-markdown.pasteAsMarkdown",
        "title": "%command.pasteAsMarkdown%"
      },
      {
        "command": "anytime-markdown.openContext",
        "title": "%command.openContext%",
        "icon": "$(note)"
      },
      {
        "command": "anytime-markdown.copyContextPath",
        "title": "%command.copyContextPath%",
        "icon": "$(clippy)"
      },
      {
        "command": "anytime-markdown.clearContext",
        "title": "%command.clearContext%",
        "icon": "$(trash)"
      },
      {
        "command": "anytime-markdown.aiLogRefresh",
        "title": "%command.aiLogRefresh%",
        "icon": "$(refresh)"
      },
      {
        "command": "anytime-markdown.aiMemoryRefresh",
        "title": "%command.aiMemoryRefresh%",
        "icon": "$(refresh)"
      }
    ],
    "customEditors": [
      {
        "viewType": "anytimeMarkdown",
        "displayName": "%customEditor.displayName%",
        "selector": [
          {
            "filenamePattern": "*.md"
          },
          {
            "filenamePattern": "*.markdown"
          }
        ],
        "priority": "option"
      }
    ],
    "configuration": {
      "title": "%configuration.title%",
      "properties": {
        "anytimeMarkdown.fontSize": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "maximum": 72,
          "description": "%configuration.fontSize.description%"
        },
        "anytimeMarkdown.editorMaxWidth": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "maximum": 10000,
          "description": "%configuration.editorMaxWidth.description%"
        }
      }
    },
    "submenus": [
      {
        "id": "anytimeMarkdown.changesMore",
        "label": "More Actions...",
        "icon": "$(ellipsis)"
      }
    ],
    "menus": {
      "anytimeMarkdown.changesMore": [
        {
          "command": "anytime-markdown.commitChanges",
          "group": "1_commit@1"
        },
        {
          "command": "anytime-markdown.pushChanges",
          "group": "1_commit@2"
        }
      ],
      "view/title": [
        {
          "command": "anytime-markdown.clearContext",
          "when": "view == anytimeMarkdown.aiNote",
          "group": "navigation@2"
        },
        {
          "command": "anytime-markdown.aiLogRefresh",
          "when": "view == anytimeMarkdown.aiLog",
          "group": "navigation@1"
        },
        {
          "command": "anytime-markdown.aiMemoryRefresh",
          "when": "view == anytimeMarkdown.aiMemory",
          "group": "navigation@1"
        },
        {
          "command": "anytime-markdown.copyContextPath",
          "when": "view == anytimeMarkdown.aiNote",
          "group": "navigation@1"
        },
        {
          "command": "anytime-markdown.toggleMdOnly",
          "when": "view == anytimeMarkdown.specDocs",
          "group": "navigation@2"
        },
        {
          "command": "anytime-markdown.specDocsCreateFile",
          "when": "view == anytimeMarkdown.specDocs && anytimeMarkdown.specDocsHasRoot",
          "group": "navigation@3"
        },
        {
          "command": "anytime-markdown.specDocsCreateFolder",
          "when": "view == anytimeMarkdown.specDocs && anytimeMarkdown.specDocsHasRoot",
          "group": "navigation@4"
        },
        {
          "command": "anytime-markdown.specDocsRefresh",
          "when": "view == anytimeMarkdown.specDocs && anytimeMarkdown.specDocsHasRoot",
          "group": "navigation@5"
        },
        {
          "command": "anytime-markdown.specDocsOpenFolder",
          "when": "view == anytimeMarkdown.specDocs && anytimeMarkdown.specDocsHasRoot",
          "group": "navigation@6"
        },
        {
          "command": "anytime-markdown.specDocsCloneRepo",
          "when": "view == anytimeMarkdown.specDocs && anytimeMarkdown.specDocsHasRoot",
          "group": "navigation@7"
        },
        {
          "command": "anytime-markdown.graphRefresh",
          "when": "view == anytimeMarkdown.graph",
          "group": "navigation@1"
        },
        {
          "command": "anytime-markdown.changesRefresh",
          "when": "view == anytimeMarkdown.changes",
          "group": "navigation@1"
        },
        {
          "submenu": "anytimeMarkdown.changesMore",
          "when": "view == anytimeMarkdown.changes",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "anytime-markdown.specDocsCreateFile",
          "when": "view == anytimeMarkdown.specDocs && viewItem == folder",
          "group": "1_new@1"
        },
        {
          "command": "anytime-markdown.specDocsCreateFolder",
          "when": "view == anytimeMarkdown.specDocs && viewItem == folder",
          "group": "1_new@2"
        },
        {
          "command": "anytime-markdown.specDocsImportFiles",
          "when": "view == anytimeMarkdown.specDocs && viewItem == folder",
          "group": "1_new@3"
        },
        {
          "command": "anytime-markdown.specDocsCreateFile",
          "when": "view == anytimeMarkdown.specDocs && viewItem == specDocsRoot",
          "group": "1_new@1"
        },
        {
          "command": "anytime-markdown.specDocsCreateFolder",
          "when": "view == anytimeMarkdown.specDocs && viewItem == specDocsRoot",
          "group": "1_new@2"
        },
        {
          "command": "anytime-markdown.specDocsImportFiles",
          "when": "view == anytimeMarkdown.specDocs && viewItem == specDocsRoot",
          "group": "1_new@3"
        },
        {
          "command": "anytime-markdown.specDocsPaste",
          "when": "view == anytimeMarkdown.specDocs && viewItem == specDocsRoot",
          "group": "1_new@4"
        },
        {
          "command": "anytime-markdown.specDocsCut",
          "when": "view == anytimeMarkdown.specDocs && viewItem != specDocsRoot",
          "group": "2_clipboard@1"
        },
        {
          "command": "anytime-markdown.specDocsCopy",
          "when": "view == anytimeMarkdown.specDocs && viewItem != specDocsRoot",
          "group": "2_clipboard@2"
        },
        {
          "command": "anytime-markdown.specDocsPaste",
          "when": "view == anytimeMarkdown.specDocs && viewItem != specDocsRoot",
          "group": "2_clipboard@3"
        },
        {
          "command": "anytime-markdown.specDocsCopyPath",
          "when": "view == anytimeMarkdown.specDocs && viewItem != specDocsRoot",
          "group": "3_path@1"
        },
        {
          "command": "anytime-markdown.specDocsCopyFileName",
          "when": "view == anytimeMarkdown.specDocs && viewItem != specDocsRoot",
          "group": "3_path@2"
        },
        {
          "command": "anytime-markdown.specDocsRename",
          "when": "view == anytimeMarkdown.specDocs && viewItem != specDocsRoot",
          "group": "4_modify@1"
        },
        {
          "command": "anytime-markdown.specDocsDelete",
          "when": "view == anytimeMarkdown.specDocs && viewItem != specDocsRoot",
          "group": "4_modify@2"
        },
        {
          "command": "anytime-markdown.switchBranch",
          "when": "view == anytimeMarkdown.specDocs && viewItem == specDocsRoot",
          "group": "3_root@1"
        },
        {
          "command": "anytime-markdown.specDocsRemoveRoot",
          "when": "view == anytimeMarkdown.specDocs && viewItem == specDocsRoot",
          "group": "3_root@2"
        },
        {
          "command": "anytime-markdown.discardAll",
          "when": "view == anytimeMarkdown.changes && viewItem == changesGroupChanges",
          "group": "inline@1"
        },
        {
          "command": "anytime-markdown.stageAll",
          "when": "view == anytimeMarkdown.changes && viewItem == changesGroupChanges",
          "group": "inline@2"
        },
        {
          "command": "anytime-markdown.unstageAll",
          "when": "view == anytimeMarkdown.changes && viewItem == changesGroupStaged",
          "group": "inline@1"
        },
        {
          "command": "anytime-markdown.stageFile",
          "when": "view == anytimeMarkdown.changes && viewItem == changesFileUnstaged",
          "group": "inline@2"
        },
        {
          "command": "anytime-markdown.discardChanges",
          "when": "view == anytimeMarkdown.changes && viewItem == changesFileUnstaged",
          "group": "inline@1"
        },
        {
          "command": "anytime-markdown.unstageFile",
          "when": "view == anytimeMarkdown.changes && viewItem == changesFileStaged",
          "group": "inline@1"
        }
      ],
      "explorer/context": [
        {
          "command": "anytime-markdown.openEditorWithFile",
          "when": "resourceLangId == markdown",
          "group": "navigation"
        },
        {
          "command": "anytime-markdown.compareWithMarkdownEditor",
          "when": "resourceLangId == markdown",
          "group": "navigation@2"
        }
      ],
      "editor/title/context": [
        {
          "command": "anytime-markdown.openEditorWithFile",
          "when": "resourceLangId == markdown",
          "group": "navigation"
        },
        {
          "command": "anytime-markdown.compareWithMarkdownEditor",
          "when": "resourceLangId == markdown",
          "group": "navigation@2"
        }
      ]
    },
    "keybindings": [
      {
        "command": "anytime-markdown.pasteAsMarkdown",
        "key": "ctrl+shift+v",
        "mac": "cmd+shift+v",
        "when": "activeCustomEditorId == anytimeMarkdown"
      },
      {
        "command": "anytime-markdown.specDocsCut",
        "key": "ctrl+x",
        "mac": "cmd+x",
        "when": "focusedView == anytimeMarkdown.specDocs"
      },
      {
        "command": "anytime-markdown.specDocsCopy",
        "key": "ctrl+c",
        "mac": "cmd+c",
        "when": "focusedView == anytimeMarkdown.specDocs"
      },
      {
        "command": "anytime-markdown.specDocsPaste",
        "key": "ctrl+v",
        "mac": "cmd+v",
        "when": "focusedView == anytimeMarkdown.specDocs"
      }
    ]
  },
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": "limited",
      "description": "Git operations and file system access require workspace trust. Editor and preview features work in untrusted workspaces.",
      "restrictedConfigurations": []
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test || echo \"vscode-test skipped (headless environment)\""
  },
  "devDependencies": {
    "@types/mocha": "10.0.10",
    "@types/node": "22.x",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/vscode": "1.109.0",
    "@types/dompurify": "3.0.5",
    "@types/diff": "7.0.2",
    "@types/plantuml-encoder": "1.4.2",
    "@vscode/test-cli": "0.0.12",
    "@vscode/test-electron": "2.5.2",
    "css-loader": "7.1.4",
    "eslint": "9.39.2",
    "style-loader": "4.0.0",
    "ts-loader": "9.5.4",
    "typescript": "5.9.3",
    "typescript-eslint": "8.54.0",
    "webpack": "5.104.1",
    "webpack-cli": "6.0.1"
  },
  "dependencies": {
    "@anytime-markdown/markdown-core": "*",
    "@mui/material": "7.3.7",
    "@mui/icons-material": "7.3.7",
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "dompurify": "3.3.3",
    "marked": "17.0.3",
    "diff": "8.0.3",
    "plantuml-encoder": "1.4.0",
    "mermaid": "11.12.3"
  }
}
