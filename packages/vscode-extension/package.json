{
  "name": "anytime-markdown",
  "displayName": "Anytime Markdown",
  "description": "markdown editor featuring Claude Code",
  "version": "0.3.0",
  "license": "MIT",
  "publisher": "kiytaka-ueda",
  "repository": {
    "type": "git",
    "url": "https://github.com/kiyotaka-ueda/anytime-markdown.git"
  },
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "markdown",
    "diff",
    "merge",
    "mermaid",
    "plantuml"
  ],
  "activationEvents": [],
  "icon": "images/camel_markdown.png",
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "anytimeMarkdown",
          "title": "Anytime Markdown",
          "icon": "images/camel-activitybar.svg"
        }
      ]
    },
    "views": {
      "anytimeMarkdown": [
        {
          "id": "anytimeMarkdown.outline",
          "name": "Outline"
        },
        {
          "id": "anytimeMarkdown.gitHistory",
          "name": "Git History"
        },
        {
          "id": "anytimeMarkdown.comments",
          "name": "Comments"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "anytimeMarkdown.outline",
        "contents": "No items."
      },
      {
        "view": "anytimeMarkdown.gitHistory",
        "contents": "No items."
      },
      {
        "view": "anytimeMarkdown.comments",
        "contents": "No comments."
      }
    ],
    "commands": [
      {
        "command": "anytime-markdown.openEditorWithFile",
        "title": "Open with Anytime"
      },
      {
        "command": "anytime-markdown.compareWithMarkdownEditor",
        "title": "Compare with Anytime",
        "enablement": "activeCustomEditorId == anytimeMarkdown"
      },
      {
        "command": "anytime-markdown.toggleSectionNumbers",
        "title": "Toggle Section Numbers",
        "icon": "$(list-ordered)"
      },
      {
        "command": "anytime-markdown.resolveComment",
        "title": "Resolve",
        "icon": "$(check)"
      },
      {
        "command": "anytime-markdown.unresolveComment",
        "title": "Reopen",
        "icon": "$(circle-outline)"
      },
      {
        "command": "anytime-markdown.deleteComment",
        "title": "Delete",
        "icon": "$(trash)"
      },
      {
        "command": "anytime-markdown.filterCommentsAll",
        "title": "All"
      },
      {
        "command": "anytime-markdown.filterCommentsOpen",
        "title": "Open"
      },
      {
        "command": "anytime-markdown.filterCommentsResolved",
        "title": "Resolved"
      },
      {
        "command": "anytime-markdown.toggleBlockElements",
        "title": "Toggle Block Elements",
        "icon": "$(symbol-misc)"
      }
    ],
    "customEditors": [
      {
        "viewType": "anytimeMarkdown",
        "displayName": "Markdown Editor",
        "selector": [
          {
            "filenamePattern": "*.md"
          },
          {
            "filenamePattern": "*.markdown"
          }
        ],
        "priority": "option"
      }
    ],
    "configuration": {
      "title": "Anytime Markdown",
      "properties": {
        "anytimeMarkdown.fontSize": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "maximum": 72,
          "description": "Font size in pixels for the editor. 0 uses the VS Code default."
        },
        "anytimeMarkdown.editorMaxWidth": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "maximum": 10000,
          "description": "Maximum width of the editor content in pixels. 0 means no limit."
        }
      }
    },
    "submenus": [
      {
        "id": "anytimeMarkdown.commentFilter",
        "label": "Filter",
        "icon": "$(filter)"
      }
    ],
    "menus": {
      "anytimeMarkdown.commentFilter": [
        {
          "command": "anytime-markdown.filterCommentsAll"
        },
        {
          "command": "anytime-markdown.filterCommentsOpen"
        },
        {
          "command": "anytime-markdown.filterCommentsResolved"
        }
      ],
      "view/item/context": [
        {
          "command": "anytime-markdown.resolveComment",
          "when": "view == anytimeMarkdown.comments && viewItem == unresolved",
          "group": "inline@1"
        },
        {
          "command": "anytime-markdown.unresolveComment",
          "when": "view == anytimeMarkdown.comments && viewItem == resolved",
          "group": "inline@1"
        },
        {
          "command": "anytime-markdown.deleteComment",
          "when": "view == anytimeMarkdown.comments",
          "group": "inline@2"
        }
      ],
      "view/title": [
        {
          "submenu": "anytimeMarkdown.commentFilter",
          "when": "view == anytimeMarkdown.comments",
          "group": "navigation@1"
        },
        {
          "command": "anytime-markdown.toggleSectionNumbers",
          "when": "view == anytimeMarkdown.outline",
          "group": "navigation@1"
        },
        {
          "command": "anytime-markdown.toggleBlockElements",
          "when": "view == anytimeMarkdown.outline",
          "group": "navigation@2"
        }
      ],
      "explorer/context": [
        {
          "command": "anytime-markdown.openEditorWithFile",
          "when": "resourceLangId == markdown",
          "group": "navigation"
        },
        {
          "command": "anytime-markdown.compareWithMarkdownEditor",
          "when": "resourceLangId == markdown",
          "group": "navigation@2"
        }
      ],
      "editor/title/context": [
        {
          "command": "anytime-markdown.openEditorWithFile",
          "when": "resourceLangId == markdown",
          "group": "navigation"
        },
        {
          "command": "anytime-markdown.compareWithMarkdownEditor",
          "when": "resourceLangId == markdown",
          "group": "navigation@2"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test || echo \"vscode-test skipped (headless environment)\""
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.109.0",
    "@types/dompurify": "^3.0.5",
    "@types/diff": "^7.0.2",
    "@types/plantuml-encoder": "^1.4.2",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "css-loader": "^7.1.4",
    "eslint": "^9.39.2",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "webpack": "^5.104.1",
    "webpack-cli": "^6.0.1"
  },
  "dependencies": {
    "@anytime-markdown/editor-core": "*",
    "@mui/material": "^7.3.7",
    "@mui/icons-material": "^7.3.7",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "dompurify": "^3.3.1",
    "marked": "^17.0.3",
    "diff": "^8.0.3",
    "plantuml-encoder": "^1.4.0",
    "mermaid": "^11.12.3"
  }
}
