{
  "name": "anytime-markdown-monorepo",
  "version": "0.9.1",
  "license": "MIT",
  "private": true,
  "scripts": {
    "version:sync": "npm version --no-git-tag-version --workspaces",
    "lint": "eslint packages/markdown-core/src packages/web-app/src",
    "lint:fix": "eslint --fix packages/markdown-core/src packages/web-app/src"
  },
  "workspaces": [
    "packages/markdown-core",
    "packages/graph-core",
    "packages/mcp-markdown",
    "packages/mcp-graph",
    "packages/cms-core",
    "packages/mcp-cms",
    "packages/mcp-cms-remote",
    "packages/vscode-markdown-extension",
    "packages/vscode-graph-extension",
    "packages/vscode-git-extension",
    "packages/vscode-extension-pack",
    "packages/web-app",
    "packages/mobile-app"
  ],
  "overrides": {
    "serialize-javascript": "7.0.5",
    "diff": "8.0.3",
    "next": "15.5.14",
    "handlebars": "4.7.9"
  },
  "devDependencies": {
    "@next/eslint-plugin-next": "^16.1.6",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "raw-loader": "4.0.2",
    "typescript-eslint": "^8.57.0"
  }
}
